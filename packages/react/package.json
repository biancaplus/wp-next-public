{
  "name": "@wp-next/react",
  "version": "0.1.1",
  "description": "wp-next React — HTML content renderer with pluggable processor pipeline",
  "license": "MIT",
  "author": "wp-next contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biancaplus/wp-next.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/biancaplus/wp-next#readme",
  "bugs": {
    "url": "https://github.com/biancaplus/wp-next/issues"
  },
  "keywords": [
    "wordpress",
    "react",
    "nextjs",
    "content-renderer",
    "wp-next"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
