{
  "name": "wp-next",
  "version": "0.1.0",
  "private": true,
  "description": "WordPress Headless 现代化迁移工具链",
  "scripts": {
    "build": "node scripts/verify.mjs build",
    "dev": "turbo dev",
    "lint": "node scripts/verify.mjs lint",
    "test": "node scripts/verify.mjs test",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "node scripts/verify.mjs build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.7.0"
}
